# LLM settings
MODEL=gemma4:e4b
EMBED_MODEL=nomic-embed-text
OLLAMA_URL=http://172.17.121.200:11434

# Paths
DATA_PATH=./data
LOGS_PATH=./logs

# Retrieval behavior
RETRIEVAL_K=5
MAX_TURNS=12

# Persona
PERSONA_NAME=Alex

# Ticketing API Integration
TICKETING_API_URL=http://your-production-url.com/tickets/unprocessed
TICKETING_UPDATE_URL=http://your-production-url.com/tickets/update
TICKETING_API_KEY=your_secret_api_key

# PostgreSQL + pgvector
# Format: postgresql+psycopg://user:password@host:port/database
PGVECTOR_CONNECTION=postgresql+psycopg://postgres:postgres@localhost:5432/agent_db
PGVECTOR_COLLECTION=it_expert_knowledge
ANALYTICS_POSTGRES_URL=postgresql+psycopg://postgres:postgres@localhost:5432/agent_db
